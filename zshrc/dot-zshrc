export XDG_CONFIG_HOME="$HOME/.config"

typeset -a zsh_config_files=(
  "$XDG_CONFIG_HOME/zsh/completion.zsh"
  "$XDG_CONFIG_HOME/zsh/keybindings.zsh"
  "$XDG_CONFIG_HOME/zsh/environment.zsh"
  "$XDG_CONFIG_HOME/zsh/secrets.zsh"
  "$XDG_CONFIG_HOME/zsh/prompt.zsh"
  "$XDG_CONFIG_HOME/zsh/aliases.zsh"
  "$XDG_CONFIG_HOME/zsh/functions.zsh"
)

for config_file in "${zsh_config_files[@]}"; do
  [ -r "$config_file" ] && source "$config_file"
done

unset config_file
unset zsh_config_files
